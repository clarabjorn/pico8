pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _update()
  update_game()
      
end

function _draw()
 cls()
	draw_game()
end

function _init()
  spiller={
    x=30,
    y=30,
    hastighed=1,
    retning=⬆️,
    b=8,
    h=8,
    maal=0
  }
  bold={
   x=40,
   y=40,
   dx=0.1,
   dy=0.1,
   b=8,
   h=8
  }
  styrke = 5
  friktion = 0.5
  maal={
  	x=8,
  	y=24,
  	b=8,
  	h=16
  }
end

function draw_game() 
  --rect(0,0,127,127,1)
  map(1,0)
  spr(1, spiller.x, spiller.y)
  spr(5, bold.x, bold.y)
  rect(maal.x,maal.y,
  maal.x+maal.b,maal.y+maal.h,
  8)
  print("maal: ".. spiller.maal)
end

function update_game()
	if btnp(⬆️) then
		if spiller.retning == ⬆️ then
			spiller.hastighed += 1
		else
		 spiller.hastighed = 1
		end
		spiller.retning = ⬆️
		spiller.y -= spiller.hastighed / 3
	end
	
	if btnp(⬇️) then
		if spiller.retning == ⬇️ then
			spiller.hastighed += 1
		else
		 spiller.hastighed = 1
		end
		spiller.retning = ⬇️
		spiller.y += spiller.hastighed / 3
	end

	if btnp(⬅️) then
	 if spiller.retning == ⬅️ then
	  spiller.hastighed += 1
	 else
  	spiller.hastighed = 1
	 end
	  spiller.retning = ⬅️
	 spiller.x -= spiller.hastighed / 3
	end

	if btnp(➡️) then
	if spiller.retning == ➡️ then
	  spiller.hastighed += 1
	 else
  	spiller.hastighed = 1
	 end
	  spiller.retning = ➡️
	 spiller.x += spiller.hastighed / 3

	 
	end
	 
	if bold.dx < -0.1 or bold.dx > 0.1 then
		bold.x += bold.dx
		bold.dx = bold.dx * 0.5
	end
	
	if bold.dy < -0.1 or bold.dy > 0.1 then
		bold.y += bold.dy
		bold.dy = bold.dy * 0.5
	end
	
	if collision(spiller, bold) then
	 local v = vector(spiller,bold)
	 local r = rnd()
	 bold.dx += v.dx * styrke * r
	 bold.dy += v.dy * styrke * r
	end
	
	if collision(bold, maal) then
	 _maal()
	end
	
	
	if abs(bold.dx) > 0.1 or
				abs(bold.dy) > 0.1 then
		bold.dx += bold.dx
		bold.dy += bold.dy
		bold.dx *= 1-friktion
		bold.dy *= 1-friktion
--	 bold.x += 5
--		bold.y += 5
--		bold.dx += 3
--		bold.dy += 3
	end
	
end

function _maal()
 spiller.x=64
 spiller.y=8
 bold.x=64
 bold.y=8
 spiller.maal+=1
end
-->8
--collision
function collision(a,b)
	if b.x > a.x + a.b then
		return false
	elseif b.y > a.y + a.h then
		return false
	elseif a.x > b.x+b.b then
		return false
	elseif a.y > b.y + b.h then
		return false
	end
	return true	
end
-->8
--vector
function vector(s,b)
	local dx = b.x - s.x
	local dy = b.y - s.y
	
	local len = sqrt(dx*dx+dy*dy)
	dx = dx/len
	dy = dy/len
	return {
		dx = dx,
		dy = dy
	}

end
