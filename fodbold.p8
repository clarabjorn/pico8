pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _update()
  update_game()  
end

function _draw()
 cls()
	draw_game()
end

function _init()
  spiller={
    x=30,
    y=30
  }
  bold={
   x=40,
   y=40
  }
end

function draw_game() 
  rect(0,0,127,127,1)
  spr(1, spiller.x, spiller.y)
  spr(5, bold.x, bold.y) 
end

function update_game()
	if btnp(⬆️) then
		spiller.y -= 1
	end
	if btnp(⬇️) then
		spiller.y += 1
	end
	if btnp(⬅️) then
	 spiller.x -= 1
	end
	if btnp(➡️) then
	 spiller.x += 1
	end
	 
	if spiller.x >= bold.x 
	 and spiller.x <= bold.x+5 then
		if spiller.y == bold.y then
			bold.x +=5
			bold.y += 5
		end
	end 
	 
end
